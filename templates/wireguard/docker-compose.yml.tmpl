services:
  wireguard:
    image: ghcr.io/wg-easy/wg-easy:14
    container_name: wireguard
    restart: unless-stopped
    ports:
      - "{{index . "vpn_port"}}:51820/udp"
      - "{{index . "web_port"}}:51821/tcp"
    environment:
      - TZ={{index . "timezone"}}
      - WG_HOST={{index . "wg_host"}}
      - PASSWORD_HASH={{index . "password_hash"}}
    cap_add:
      - NET_ADMIN
    sysctls:
      - net.ipv4.conf.all.src_valid_mark=1
      - net.ipv4.ip_forward=1
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 200
    security_opt:
      - no-new-privileges:true
    volumes:
      - {{index . "data_dir"}}/config:/etc/wireguard
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:51821 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
