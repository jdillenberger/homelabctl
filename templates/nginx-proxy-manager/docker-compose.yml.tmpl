services:
  nginx-proxy-manager:
    image: jc21/nginx-proxy-manager:2.13.7
    container_name: nginx-proxy-manager
    restart: unless-stopped
    ports:
      - "{{index . "http_port"}}:80"
      - "{{index . "https_port"}}:443"
      - "{{index . "web_port"}}:81"
    environment:
      - TZ={{index . "timezone"}}
      - DB_MYSQL_HOST=nginx-proxy-manager-db
      - DB_MYSQL_PORT=3306
      - DB_MYSQL_USER=npm
      - DB_MYSQL_PASSWORD={{index . "db_password"}}
      - DB_MYSQL_NAME=npm
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:81/api/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    volumes:
      - {{index . "data_dir"}}/data:/data
      - {{index . "data_dir"}}/letsencrypt:/etc/letsencrypt
    depends_on:
      nginx-proxy-manager-db:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  nginx-proxy-manager-db:
    image: mariadb:11.4
    container_name: nginx-proxy-manager-db
    restart: unless-stopped
    shm_size: '256m'
    environment:
      - TZ={{index . "timezone"}}
      - MYSQL_ROOT_PASSWORD={{index . "db_root_password"}}
      - MYSQL_DATABASE=npm
      - MYSQL_USER=npm
      - MYSQL_PASSWORD={{index . "db_password"}}
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 100
    volumes:
      - {{index . "data_dir"}}/db:/var/lib/mysql
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 5
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
