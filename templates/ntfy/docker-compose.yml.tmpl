services:
  ntfy:
    image: binwiederhier/ntfy:v2.11.0
    container_name: ntfy
    command: serve
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:80"
    environment:
      - TZ={{index . "timezone"}}
    deploy:
      resources:
        limits:
          memory: 128M
          pids: 200
    volumes:
      - {{index . "data_dir"}}/cache:/var/cache/ntfy
      - {{index . "data_dir"}}/config:/etc/ntfy
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:80/v1/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
