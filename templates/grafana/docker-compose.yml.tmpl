services:
  grafana:
    image: grafana/grafana-oss:11.6.0
    container_name: grafana
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:3000"
    environment:
      - TZ={{index . "timezone"}}
      - GF_SECURITY_ADMIN_PASSWORD={{index . "admin_password"}}
    volumes:
      - {{index . "data_dir"}}/grafana-data:/var/lib/grafana
    depends_on:
      grafana-prometheus:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:3000/api/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

  grafana-prometheus:
    image: prom/prometheus:v3.3.0
    container_name: grafana-prometheus
    restart: unless-stopped
    ports:
      - "{{index . "prometheus_port"}}:9090"
    environment:
      - TZ={{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/prometheus-data:/prometheus
      - {{index . "data_dir"}}/config/prometheus.yml:/etc/prometheus/prometheus.yml:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:9090/-/healthy || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
