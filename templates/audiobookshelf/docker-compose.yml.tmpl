services:
  audiobookshelf:
    image: ghcr.io/advplyr/audiobookshelf:2.32.1
    container_name: audiobookshelf
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:13378"
    environment:
      - TZ={{index . "timezone"}}
    volumes:
      - {{if index . "audiobooks_path"}}{{index . "audiobooks_path"}}{{else}}{{index . "data_dir"}}/audiobooks{{end}}:/audiobooks
      - {{if index . "podcasts_path"}}{{index . "podcasts_path"}}{{else}}{{index . "data_dir"}}/podcasts{{end}}:/podcasts
      - {{index . "data_dir"}}/config:/config
      - {{index . "data_dir"}}/metadata:/metadata
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:13378/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
