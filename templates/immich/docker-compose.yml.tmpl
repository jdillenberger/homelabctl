services:
  immich-server:
    image: ghcr.io/immich-app/immich-server:release
    container_name: immich
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:2283"
    environment:
      - DB_URL=postgres://immich:{{index . "db_password"}}@immich-db:5432/immich
      - REDIS_HOSTNAME=immich-redis
      - IMMICH_MACHINE_LEARNING_URL=http://immich-machine-learning:3003
      - TZ={{index . "timezone"}}
    volumes:
      - {{if index . "upload_location"}}{{index . "upload_location"}}{{else}}{{index . "data_dir"}}/upload{{end}}:/usr/src/app/upload
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:2283/api/server/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 2G
          pids: 200
    depends_on:
      immich-db:
        condition: service_healthy
      immich-redis:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  immich-machine-learning:
    image: ghcr.io/immich-app/immich-machine-learning:release
    container_name: immich-machine-learning
    restart: unless-stopped
    environment:
      - TZ={{index . "timezone"}}
    deploy:
      resources:
        limits:
          memory: 4G
          pids: 200
    volumes:
      - {{index . "data_dir"}}/model-cache:/cache
    healthcheck:
      test: ["CMD-SHELL", "python3 -c 'import urllib.request; urllib.request.urlopen(\"http://localhost:3003/ping\")' || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  immich-db:
    image: ghcr.io/immich-app/postgres:16-vectorchord0.3.0-pgvectors0.3.0
    container_name: immich-db
    restart: unless-stopped
    shm_size: '256m'
    environment:
      - POSTGRES_DB=immich
      - POSTGRES_USER=immich
      - POSTGRES_PASSWORD={{index . "db_password"}}
      - POSTGRES_INITDB_ARGS=--data-checksums
      - TZ={{index . "timezone"}}
    deploy:
      resources:
        limits:
          memory: 1G
          pids: 100
    volumes:
      - {{index . "data_dir"}}/db:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U immich"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  immich-redis:
    image: redis:7-alpine
    container_name: immich-redis
    restart: unless-stopped
    environment:
      - TZ={{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/redis:/data
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 50
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
