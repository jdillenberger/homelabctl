services:
  searxng:
    image: docker.io/searxng/searxng:latest
    container_name: searxng
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:8080"
    environment:
      - SEARXNG_BASE_URL=http://localhost:{{index . "web_port"}}/
      - SEARXNG_SECRET={{index . "secret_key"}}
      - TZ={{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/config:/etc/searxng:rw
      - {{index . "data_dir"}}/cache:/var/cache/searxng:rw
    depends_on:
      searxng-valkey:
        condition: service_healthy
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    healthcheck:
      test: ["CMD-SHELL", "wget --spider -q http://localhost:8080/healthz || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

  searxng-valkey:
    image: docker.io/valkey/valkey:8-alpine
    container_name: searxng-valkey
    restart: unless-stopped
    command: valkey-server --save 30 1 --loglevel warning
    volumes:
      - {{index . "data_dir"}}/valkey:/data
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 100
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
