services:
  hedgedoc:
    image: quay.io/hedgedoc/hedgedoc:1.10.7
    container_name: hedgedoc
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:3000"
    environment:
      - CMD_DB_URL=postgres://hedgedoc:{{index . "db_password"}}@hedgedoc-db:5432/hedgedoc
      - CMD_SESSION_SECRET={{index . "session_secret"}}
      - CMD_DOMAIN={{index . "routing_domain"}}
      - CMD_URL_ADDPORT=false
      - CMD_PROTOCOL_USESSL={{index . "https_enabled"}}
      - TZ={{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/uploads:/hedgedoc/public/uploads
    healthcheck:
      test: ["CMD", "node", "/hedgedoc/healthcheck.mjs"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    depends_on:
      hedgedoc-db:
        condition: service_healthy
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

  hedgedoc-db:
    image: postgres:16-alpine
    container_name: hedgedoc-db
    restart: unless-stopped
    shm_size: '256m'
    environment:
      - POSTGRES_DB=hedgedoc
      - POSTGRES_USER=hedgedoc
      - POSTGRES_PASSWORD={{index . "db_password"}}
      - TZ={{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/db:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U hedgedoc"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 100
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
