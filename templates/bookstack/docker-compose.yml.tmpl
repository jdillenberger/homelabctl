services:
  bookstack:
    image: lscr.io/linuxserver/bookstack:25.02
    container_name: bookstack
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:80"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ={{index . "timezone"}}
      - APP_URL={{index . "routing_url"}}
      - DB_HOST=bookstack-db
      - DB_DATABASE=bookstack
      - DB_USER=bookstack
      - DB_PASS={{index . "db_password"}}
    volumes:
      - {{index . "data_dir"}}/config:/config
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:80/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    depends_on:
      bookstack-db:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  bookstack-db:
    image: mariadb:11.4
    container_name: bookstack-db
    restart: unless-stopped
    shm_size: '256m'
    environment:
      - TZ={{index . "timezone"}}
      - MYSQL_ROOT_PASSWORD={{index . "db_password"}}
      - MYSQL_DATABASE=bookstack
      - MYSQL_USER=bookstack
      - MYSQL_PASSWORD={{index . "db_password"}}
    volumes:
      - {{index . "data_dir"}}/db:/var/lib/mysql
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 100
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
