services:
  stirling-pdf:
    image: stirlingtools/stirling-pdf:0.46.1
    container_name: stirling-pdf
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:8080"
    environment:
      - TZ={{index . "timezone"}}
      - DOCKER_ENABLE_SECURITY=false
      - INSTALL_BOOK_AND_ADVANCED_HTML_OPS=false
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    volumes:
      - {{index . "data_dir"}}/data:/usr/share/tessdata
      - {{index . "data_dir"}}/configs:/configs
      - {{index . "data_dir"}}/logs:/logs
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8080 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
