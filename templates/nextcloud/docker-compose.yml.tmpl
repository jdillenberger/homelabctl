services:
  nextcloud:
    image: nextcloud:32.0.6
    container_name: nextcloud
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:80"
    environment:
      - TZ={{index . "timezone"}}
      - MYSQL_HOST=nextcloud-db
      - MYSQL_DATABASE={{index . "db_name"}}
      - MYSQL_USER={{index . "db_user"}}
      - MYSQL_PASSWORD={{index . "db_user_password"}}
      - NEXTCLOUD_ADMIN_USER={{index . "nextcloud_admin_user"}}
      - NEXTCLOUD_ADMIN_PASSWORD={{index . "nextcloud_admin_password"}}
      - NEXTCLOUD_TRUSTED_DOMAINS=localhost {{index . "routing_domain"}}
{{- if eq (index . "https_enabled") "true"}}
      - OVERWRITEPROTOCOL=https
{{- end}}
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:80/status.php || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    deploy:
      resources:
        limits:
          memory: 1G
          pids: 200
    volumes:
      - {{index . "data_dir"}}/html:/var/www/html
{{- if ne (index . "ca_cert_path") ""}}
      - {{index . "data_dir"}}/ca-bundle.crt:/etc/ssl/certs/ca-certificates.crt:ro
      - {{index . "ca_cert_path"}}:/usr/local/share/ca-certificates/homelabctl-ca.crt:ro
{{- end}}
    depends_on:
      nextcloud-db:
        condition: service_healthy
    extra_hosts:
      - "{{index . "routing_domain"}}:host-gateway"
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  nextcloud-db:
    image: mariadb:11.4
    container_name: nextcloud-db
    restart: unless-stopped
    shm_size: '256m'
    environment:
      - TZ={{index . "timezone"}}
      - MYSQL_ROOT_PASSWORD={{index . "db_password"}}
      - MYSQL_DATABASE={{index . "db_name"}}
      - MYSQL_USER={{index . "db_user"}}
      - MYSQL_PASSWORD={{index . "db_user_password"}}
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 100
    volumes:
      - {{index . "data_dir"}}/db:/var/lib/mysql
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 5
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
