services:
  matrix:
    image: matrixdotorg/synapse:v1.148.0
    container_name: matrix
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:8008"
    environment:
      - SYNAPSE_SERVER_NAME={{index . "server_name"}}
      - SYNAPSE_REPORT_STATS=no
      - POSTGRES_HOST=matrix-db
      - POSTGRES_DB=synapse
      - POSTGRES_USER=synapse
      - POSTGRES_PASSWORD={{index . "db_password"}}
      - SYNAPSE_REGISTRATION_SHARED_SECRET={{index . "registration_shared_secret"}}
      - TZ={{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/data:/data
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8008/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 1G
    depends_on:
      matrix-db:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    pids_limit: 200
    networks:
      - {{index . "network"}}

  matrix-db:
    image: postgres:16-alpine
    container_name: matrix-db
    restart: unless-stopped
    shm_size: '256m'
    environment:
      - POSTGRES_DB=synapse
      - POSTGRES_USER=synapse
      - POSTGRES_PASSWORD={{index . "db_password"}}
      - POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C
      - TZ={{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/db:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U synapse"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 512M
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    pids_limit: 100
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
