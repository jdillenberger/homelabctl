services:
  matrix:
    image: matrixdotorg/synapse:latest
    container_name: matrix
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:8008"
    environment:
      - SYNAPSE_SERVER_NAME={{index . "server_name"}}
      - SYNAPSE_REPORT_STATS=no
      - SYNAPSE_NO_TLS=1
      - POSTGRES_HOST=matrix-db
      - POSTGRES_DB=synapse
      - POSTGRES_USER=synapse
      - POSTGRES_PASSWORD={{index . "db_password"}}
      - SYNAPSE_REGISTRATION_SHARED_SECRET={{index . "registration_shared_secret"}}
    volumes:
      - {{index . "data_dir"}}/data:/data
    depends_on:
      matrix-db:
        condition: service_healthy
    networks:
      - homelabctl-net

  matrix-db:
    image: postgres:16-alpine
    container_name: matrix-db
    restart: unless-stopped
    environment:
      - POSTGRES_DB=synapse
      - POSTGRES_USER=synapse
      - POSTGRES_PASSWORD={{index . "db_password"}}
      - POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C
    volumes:
      - {{index . "data_dir"}}/db:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U synapse"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - homelabctl-net

networks:
  homelabctl-net:
    external: true
