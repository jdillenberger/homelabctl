services:
  umami:
    image: ghcr.io/umami-software/umami:postgresql-v2.16
    container_name: umami
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:3000"
    environment:
      - DATABASE_URL=postgresql://umami:{{index . "db_password"}}@umami-db:5432/umami
      - APP_SECRET={{index . "app_secret"}}
      - TZ={{index . "timezone"}}
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:3000/api/heartbeat || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 200
    depends_on:
      umami-db:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  umami-db:
    image: postgres:16-alpine
    container_name: umami-db
    restart: unless-stopped
    shm_size: '256m'
    environment:
      - POSTGRES_DB=umami
      - POSTGRES_USER=umami
      - POSTGRES_PASSWORD={{index . "db_password"}}
      - TZ={{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/db:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U umami"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 100
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
