services:
  minio:
    image: minio/minio:RELEASE.2025-02-28T09-55-16Z
    container_name: minio
    command: server /data --console-address ":9001"
    restart: unless-stopped
    ports:
      - "{{index . "api_port"}}:9000"
      - "{{index . "console_port"}}:9001"
    environment:
      - MINIO_ROOT_USER={{index . "root_user"}}
      - MINIO_ROOT_PASSWORD={{index . "root_password"}}
      - TZ={{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/data:/data
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:9000/minio/health/live || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 1G
          pids: 200
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
