services:
  gitlab:
    image: gitlab/gitlab-ce:latest
    container_name: gitlab
    restart: unless-stopped
    hostname: gitlab
    ports:
      - "{{index . "web_port"}}:80"
      - "{{index . "ssh_port"}}:22"
    environment:
      GITLAB_OMNIBUS_CONFIG: |
        external_url '{{index . "external_url"}}'
        gitlab_rails['initial_root_password'] = '{{index . "root_password"}}'
        nginx['listen_port'] = 80
        nginx['listen_https'] = false
        gitlab_rails['gitlab_shell_ssh_port'] = {{index . "ssh_port"}}
    volumes:
      - {{index . "data_dir"}}/config:/etc/gitlab
      - {{index . "data_dir"}}/logs:/var/log/gitlab
      - {{index . "data_dir"}}/data:/var/opt/gitlab
    shm_size: '256m'
    networks:
      - homelabctl-net

networks:
  homelabctl-net:
    external: true
