services:
  beszel:
    image: henrygd/beszel:0.18.4
    container_name: beszel
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:8090"
    environment:
      - TZ={{index . "timezone"}}
    deploy:
      resources:
        limits:
          memory: 128M
          pids: 200
    volumes:
      - {{index . "data_dir"}}/data:/beszel_data
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:8090 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
