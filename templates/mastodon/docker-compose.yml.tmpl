x-mastodon-env: &mastodon-env
  LOCAL_DOMAIN: {{index . "local_domain"}}
  REDIS_HOST: mastodon-redis
  REDIS_PORT: "6379"
  DB_HOST: mastodon-db
  DB_USER: mastodon
  DB_NAME: mastodon_production
  DB_PASS: {{index . "db_password"}}
  DB_PORT: "5432"
  SECRET_KEY_BASE: {{index . "secret_key_base"}}
  OTP_SECRET: {{index . "otp_secret"}}
  VAPID_PRIVATE_KEY: {{index . "vapid_private_key"}}
  VAPID_PUBLIC_KEY: {{index . "vapid_public_key"}}
  ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY: {{index . "active_record_encryption_primary_key"}}
  ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY: {{index . "active_record_encryption_deterministic_key"}}
  ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT: {{index . "active_record_encryption_key_derivation_salt"}}
  TZ: {{index . "timezone"}}

services:
  mastodon-web:
    image: ghcr.io/mastodon/mastodon:v4.5.7
    container_name: mastodon
    restart: unless-stopped
    command: bash -c "rm -f /mastodon/tmp/pids/server.pid; bundle exec rails s -p 3000"
    ports:
      - "{{index . "web_port"}}:3000"
    environment:
      <<: *mastodon-env
    volumes:
      - {{index . "data_dir"}}/public-system:/mastodon/public/system
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:3000/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    deploy:
      resources:
        limits:
          memory: 1G
    depends_on:
      mastodon-db:
        condition: service_healthy
      mastodon-redis:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  mastodon-streaming:
    image: ghcr.io/mastodon/mastodon-streaming:v4.5.7
    container_name: mastodon-streaming
    restart: unless-stopped
    command: node ./streaming
    ports:
      - "{{index . "streaming_port"}}:4000"
    environment:
      <<: *mastodon-env
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:4000/api/v1/streaming/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    deploy:
      resources:
        limits:
          memory: 512M
    depends_on:
      mastodon-db:
        condition: service_healthy
      mastodon-redis:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  mastodon-sidekiq:
    image: ghcr.io/mastodon/mastodon:v4.5.7
    container_name: mastodon-sidekiq
    restart: unless-stopped
    command: bundle exec sidekiq
    environment:
      <<: *mastodon-env
    volumes:
      - {{index . "data_dir"}}/public-system:/mastodon/public/system
    healthcheck:
      test: ["CMD-SHELL", "ps aux | grep '[s]idekiq' || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 1G
    depends_on:
      mastodon-db:
        condition: service_healthy
      mastodon-redis:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  mastodon-db:
    image: postgres:16-alpine
    container_name: mastodon-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: mastodon_production
      POSTGRES_USER: mastodon
      POSTGRES_PASSWORD: {{index . "db_password"}}
      TZ: {{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/db:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U mastodon -d mastodon_production"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 512M
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

  mastodon-redis:
    image: redis:7-alpine
    container_name: mastodon-redis
    restart: unless-stopped
    environment:
      TZ: {{index . "timezone"}}
    volumes:
      - {{index . "data_dir"}}/redis:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 256M
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
